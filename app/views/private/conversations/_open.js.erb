// εύρεση υπάρχοντος popup
var existing = document.getElementById("pc-<%= @conversation.id %>");

if (existing) {
  // scroll στο τελευταίο μήνυμα αν υπάρχει ήδη
  var messages = document.getElementById("messages-pc-<%= @conversation.id %>");
  if (messages) { messages.scrollTop = messages.scrollHeight; }
} else {
  // προσθήκη στο DOM αν δεν υπάρχει
  document.body.insertAdjacentHTML('beforeend', "<%= j(render partial: 'private/conversations/conversation', locals: { conversation: @conversation }) %>");
  var messages = document.getElementById("messages-pc-<%= @conversation.id %>");
  if (messages) { messages.scrollTop = messages.scrollHeight; }
}