<h2>Conversation with <%= @other_user.name || @other_user.email %></h2>

<%# κουμπί δημιουργίας group conversation %>
<% available_contacts = current_user.contacts
     .map(&:contact_user)
     .reject { |u| u == @other_user } %>
<% if available_contacts.any? %>
  <div style="margin-bottom: 15px;">
    <strong style="font-size:13px; color:#aaa;">Upgrade to group chat — add a contact:</strong>
    <% available_contacts.each do |contact| %>
      <%= button_to "➕ #{contact.name}",
          group_conversations_path,
          params: {
            creator_id: current_user.id,
            private_conversation_id: @conversation.id,
            group_conversation: { id: contact.id }
          },
          class: "btn btn-default btn-xs",
          style: "margin: 3px;",
          data: { turbo: false } %>
    <% end %>
  </div>
<% end %>

<%# μηνύματα %>
<div style="border: 1px solid #3a4f63; padding: 15px; height: 400px;
            overflow-y: scroll; background: #2b3e50;" id="private-messages">
  <% @messages.each do |message| %>
    <div style="margin: 10px 0;
                text-align: <%= message.user == current_user ? 'right' : 'left' %>;">
      <strong style="font-size:12px; color:#aaa;"><%= message.user.name || message.user.email %></strong>
      <p style="background: <%= message.user == current_user ? '#df691a' : '#3a4f63' %>;
                color: white; display: inline-block; padding: 8px 12px;
                border-radius: 10px; max-width: 70%; word-wrap: break-word;">
        <%= message.body %>
      </p>
      <small style="color:#aaa; display:block;">
        <%= message.created_at.strftime("%H:%M") %>
      </small>
    </div>
  <% end %>
</div>

<hr>

<%# φόρμα αποστολής μηνύματος %>
<%= form_with url: "/conversations/#{@conversation.id}/messages", method: :post,
    data: { turbo: false } do |f| %>
  <%= f.text_area :body, placeholder: "Write a message...", rows: 3,
      class: "form-control", style: "margin-bottom:8px;" %>
  <%= f.submit "Send", class: "btn btn-primary" %>
<% end %>

<%= link_to "Back to Inbox", conversations_path, class: "btn btn-default",
    style: "margin-top:8px;" %>
<%= button_to "Delete Conversation", conversation_path(@conversation),
    method: :delete,
    class: "btn btn-danger",
    style: "margin-top:8px;",
    data: { turbo_confirm: "Διαγραφή συνομιλίας;" } %>