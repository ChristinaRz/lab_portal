<h1><%= @post.title %></h1>
<p><%= @post.body %></p>
<small>by <%= @post.user.name || @post.user.email %></small>

<% if @post.user == current_user %>
  <%= link_to "Edit", edit_post_path(@post) %>
  <%= button_to "Delete", post_path(@post), method: :delete,
      data: { turbo_confirm: "Delete this post?" } %>
<% else %>
  <%# Κουμπί αποστολής μηνύματος %>
  <%= form_with url: private_conversations_path(post_id: @post.id),
      data: { turbo: false } do |f| %>
    <%= hidden_field_tag :message_body, "Hi! I saw your post: #{@post.title}" %>
    <%= f.submit "Send Message", class: "btn btn-primary" %>
  <% end %>
<% end %>

<hr>
<h3>Comments</h3>

<% @post.comments.each do |comment| %>
  <div style="margin: 8px 0; padding: 8px; border: 1px solid #eee;">
    <p><%= comment.body %></p>
    <small>by <%= comment.user.name || comment.user.email %></small>
    <% if comment.user == current_user %>
      <%= button_to "Delete", post_comment_path(@post, comment),
          method: :delete,
          data: { turbo_confirm: "Delete this comment?" } %>
    <% end %>
  </div>
<% end %>

<hr>
<h3>Add a comment</h3>
<%= form_with url: post_comments_path(@post), model: [@post, Comment.new] do |f| %>
  <%= f.text_area :body, placeholder: "Write a comment..." %>
  <%= f.submit "Post Comment" %>
<% end %>

<%= link_to "Back to Posts", posts_path %>